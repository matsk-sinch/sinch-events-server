# Server Configuration
SERVER_PORT=3001

# Sinch Event Configuration
# See https://developers.sinch.com/docs/conversation/callbacks
CONVERSATION_SINCH_EVENT_SECRET=

# Set to true in production to validate Sinch callback signatures
ENSURE_VALID_SIGNATURE=false

# MongoDB
MONGODB_URI=mongodb://admin:change-me@localhost:27017/sinch_events?authSource=admin
MONGODB_DATABASE=sinch_events
MONGODB_COLLECTION=events

# Optional: protect GET /events endpoints (Authorization: Bearer <key>)
QUERY_API_KEY=
